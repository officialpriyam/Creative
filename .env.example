# =================================================================================
# LOCAL WEB SCRAPING
# =================================================================================
# URL scraping, markdown extraction, brand extraction, and screenshots run locally
# through Playwright, Readability, JSDOM, and Turndown. No scraping API key is needed.
#
# Optional: configure a self-hosted SearXNG instance to enable search terms.
# Direct URL cloning works without this.
# SEARXNG_URL=http://localhost:8080

# =================================================================================
# SANDBOX PROVIDER - Choose Option 1 OR 2
# =================================================================================

# Option 1: Vercel Sandbox (recommended - default)
SANDBOX_PROVIDER=vercel

# Method a: OIDC Token (recommended for development)
# Run `vercel link` then `vercel env pull` to get VERCEL_OIDC_TOKEN automatically
VERCEL_OIDC_TOKEN=auto_generated_by_vercel_env_pull

# Method b: Personal Access Token (for production or when OIDC unavailable)
# VERCEL_TEAM_ID=team_xxxxxxxxx
# VERCEL_PROJECT_ID=prj_xxxxxxxxx
# VERCEL_TOKEN=vercel_xxxxxxxxxxxx

# Option 2: E2B Sandbox
# SANDBOX_PROVIDER=e2b
# E2B_API_KEY=your_e2b_api_key

# =================================================================================
# AI PROVIDERS - Need at least one
# =================================================================================

# Creative defaults to `free/auto`, which uses one of these free/free-tier paths:
# 1. GROQ_API_KEY -> openai/gpt-oss-20b
# 2. GEMINI_API_KEY -> google/gemini-2.5-flash-lite
# 3. OPENROUTER_API_KEY -> openrouter/free
GROQ_API_KEY=your_groq_api_key
GEMINI_API_KEY=your_gemini_api_key
OPENROUTER_API_KEY=your_openrouter_api_key

# Optional paid/provider-specific keys
AI_GATEWAY_API_KEY=your_ai_gateway_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key

# Optional Morph Fast Apply
MORPH_API_KEY=your_fast_apply_key
